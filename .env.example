# Resend API Key
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive contact form submissions
CONTACT_EMAIL=hello@picode.com.au

# From email address (requires verified domain in Resend)
# Leave empty to use Resend test domain: onboarding@resend.dev
RESEND_FROM_EMAIL=

# Calendly URL for scheduling
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/event-name
